ANTHROPIC_API_KEY=
EXA_API_KEY=
RESEND_API_KEY=
SUPABASE_URL=
# NOT the publishable key — use secret/service_role from Supabase → Settings → API
# New format: sb_secret_…   Legacy format: eyJ… (service_role JWT)
SUPABASE_SERVICE_ROLE_KEY=

# Browser-side auth (Supabase Auth via Google OAuth). Safe to expose — these are public.
# NEXT_PUBLIC_SUPABASE_URL is the same value as SUPABASE_URL.
NEXT_PUBLIC_SUPABASE_URL=
# The anon / publishable key from Supabase → Settings → API (NOT the service_role key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Email delivery
# TEST MODE (no domain): FROM must be onboarding@resend.dev and recipients must be
# the email you used to sign up for Resend — no other addresses allowed.
# PRODUCTION: verify a domain at resend.com/domains, then use e.g. newsletter@yourdomain.com
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Newsletter Generator
RESEND_REPLY_TO=you@example.com
# Free tier: only your Resend signup email; overrides profile recipients when set
RESEND_TO_EMAIL=you@example.com
